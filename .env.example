# Configuration Supabase (Front & API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Authentification SecuPRO Admin
BOSS_ADMIN_PASSWORD=use-a-long-random-secret

# Paiements & Abonnements (Stripe)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Intelligence Artificielle (SecuIA)
ANTHROPIC_API_KEY=sk-ant-...

# Emails Transactionnels (Resend)
RESEND_API_KEY=re_...

# Tâches Planifiées (Vercel Cron)
CRON_SECRET=your-cron-secret

# Application URL
NEXT_PUBLIC_APP_URL=https://secupro.app

# Google Search Console — service account (server only)
GOOGLE_CLIENT_EMAIL=secupro@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GSC_SITE_URL=https://secupro.app/
