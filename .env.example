NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Admin portal (/boss-admin-portal) — server only, never NEXT_PUBLIC_
BOSS_ADMIN_PASSWORD=use-a-long-random-secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Search Console — service account (server only)
# 1. Crée un service account sur console.cloud.google.com
# 2. Active l'API "Google Search Console API"
# 3. Ajoute l'email du service account dans GSC > Paramètres > Utilisateurs
# 4. Copie l'email et la clé privée (JSON) ci-dessous
GOOGLE_CLIENT_EMAIL=secupro@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GSC_SITE_URL=https://secupro.app/
